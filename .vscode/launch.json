{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Train MixFormer Distill",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/lib/train/train_script.py",
            "args": [
                "--script",
                "mixformer2_vit",
                "--config",
                "student_288_depth12",
                "--save_dir",
                ".",
                "--use_lmdb",
                "0",
                "--script_prv",
                "None",
                "--config_prv",
                "baseline",
                "--distill",
                "1",
                "--script_teacher",
                "mixformer_vit",
                "--config_teacher",
                "teacher_mixvit_b",
                "--checkpoint_teacher_path",
                "./models/mixformer_vit_base_online.pth.tar"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Distributed Train",
            "type": "debugpy",
            "request": "launch",
            "module": "torch.distributed.run",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "--nproc_per_node",
                "4",
                "lib/train/run_training.py",
                "--script",
                "mixformer2_vit",
                "--config",
                "student_288_depth12",
                "--save_dir",
                ".",
                "--use_lmdb",
                "0",
                "--distill",
                "1",
                "--config_prv",
                "baseline",
                "--script_teacher",
                "mixformer_vit",
                "--config_teacher",
                "teacher_mixvit_b",
                "--checkpoint_teacher_path",
                "./models/mixformer_vit_base_online.pth.tar"
            ],
            "env": {
                "CUDA_VISIBLE_DEVICES": "0, 1, 2, 3",
                "PYTHONPATH": "${workspaceFolder}:${workspaceFolder}/lib/train"
            },
            "justMyCode": true
        },
        {
            "name": "video_demo",
            "type": "debugpy",
            "request": "launch",
            "program": "tracking/video_demo.py",
            "console": "integratedTerminal",
            "args": [
                "mixformer2_vit_online", // 对应experiments/<script_name>/中的文件夹名称
                "224_depth4_mlp1_score", // 对应experiments/<tracker_name>/中配置文件的名称
                "/home/tl/data_80/data/video/110/RGB/bird/big_bird_9.18/Smart_Record_00009_20250918-055817_279166.mp4",
                "--params__model",
                "models/MixFormerV2/mixformerv2_small.pth.tar",
                "--params__search_area_scale",
                "5.0",
                "--zoomin",
                "--save_video"
            ],
            "env": {
                "DISPLAY": "tl-Ai:10.0"
            }
        },
        {
            "name": "Export ONNX Model",
            "type": "debugpy",
            "request": "launch",
            "program": "export_onnx.py",
            "console": "integratedTerminal",
            "args": [
                "--checkpoint",
                "./models/MixFormerV2/mixformerv2_small.pth.tar",
                "--config_name",
                "224_depth4_mlp1_score",
                "--output",
                "./models/mixformerv2_online_small.onnx",
                "--batch_mode",
                "static",
                "--batch_size",
                "1",
                "--opset_version",
                "17"
            ],
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}